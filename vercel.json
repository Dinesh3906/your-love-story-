{
    "version": 2,
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/app-ads.txt",
            "destination": "/app-ads.txt"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}